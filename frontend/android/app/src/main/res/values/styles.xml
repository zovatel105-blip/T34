<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- Tema principal - Modo NO-OVERLAY (estilo TikTok) -->
    <!-- El contenido NO se extiende detrás de la status bar. -->
    <!-- La status bar tiene su propio espacio con color dinámico. -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>

        <!-- Permitir cambiar color de status bar programáticamente -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- Status bar NEGRA por defecto (el plugin Capacitor la cambia dinámicamente) -->
        <item name="android:statusBarColor">#000000</item>

        <!-- Navigation bar negra -->
        <item name="android:navigationBarColor">#000000</item>

        <!-- Compatibilidad con notches / cutouts -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>

        <!-- Android 10+: sin scrim automático -->
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>
</resources>
